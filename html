<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Feliz Dia das Mães, Carolina!</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Montserrat:wght@300;400;500&display=swap" rel="stylesheet">
<style>
* { margin:0; padding:0; box-sizing:border-box; }
body { background:#0d0809; color:#f5efe8; font-family:'Montserrat',sans-serif; min-height:100vh; overflow-x:hidden; }

.petals { position:fixed; top:0; left:0; width:100%; height:100%; pointer-events:none; z-index:0; overflow:hidden; }
.petal { position:absolute; width:8px; height:12px; background:radial-gradient(ellipse at center, #c8536a 0%, #8b2335 100%); border-radius:50% 0 50% 0; opacity:0; animation:fall linear infinite; }
@keyframes fall { 0%{transform:translateY(-20px) rotate(0deg);opacity:0} 10%{opacity:0.6} 90%{opacity:0.3} 100%{transform:translateY(110vh) rotate(360deg);opacity:0} }

.hero { position:relative; z-index:1; min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:60px 20px; text-align:center; }
.rose-decoration { font-size:3rem; margin-bottom:24px; animation:bloom 3s ease-in-out infinite alternate; filter:drop-shadow(0 0 20px rgba(200,83,106,0.5)); }
@keyframes bloom { from{transform:scale(1) rotate(-3deg)} to{transform:scale(1.08) rotate(3deg)} }
.subtitle-top { font-family:'Cormorant Garamond',serif; font-style:italic; font-size:1.1rem; color:#c8819a; letter-spacing:4px; text-transform:uppercase; margin-bottom:16px; }
.name { font-family:'Cormorant Garamond',serif; font-size:clamp(2.5rem,8vw,5rem); font-weight:300; color:#f5efe8; line-height:1.1; margin-bottom:8px; }
.name span { color:#e8a0b0; font-style:italic; }
.divider { width:80px; height:1px; background:linear-gradient(to right,transparent,#c8536a,transparent); margin:24px auto; }
.hero-text { font-family:'Cormorant Garamond',serif; font-size:1.25rem; font-style:italic; color:#c8a0aa; max-width:500px; line-height:1.8; }

.photos-section { position:relative; z-index:1; padding:20px 20px 60px; display:flex; flex-direction:column; align-items:center; }
.photo-card { max-width:400px; width:100%; }
.photo-frame { position:relative; border:1px solid rgba(200,83,106,0.3); padding:12px; background:rgba(255,255,255,0.03); }
.photo-frame img { width:100%; height:420px; object-fit:cover; display:block; filter:sepia(0.15) contrast(1.05); }
.photo-caption { text-align:center; margin-top:20px; }
.photo-caption p { font-family:'Cormorant Garamond',serif; font-style:italic; color:#c8a0aa; font-size:1rem; line-height:1.7; }
.corner-dec { position:absolute; width:30px; height:30px; border-color:rgba(200,83,106,0.5); border-style:solid; }
.corner-dec.tl { top:6px; left:6px; border-width:1px 0 0 1px; }
.corner-dec.tr { top:6px; right:6px; border-width:1px 1px 0 0; }
.corner-dec.bl { bottom:6px; left:6px; border-width:0 0 1px 1px; }
.corner-dec.br { bottom:6px; right:6px; border-width:0 1px 1px 0; }

/* PRESENTE */
.gift-section { position:relative; z-index:1; padding:20px 20px 80px; display:flex; flex-direction:column; align-items:center; }

.gift-btn {
  font-family:'Cormorant Garamond',serif;
  font-size:1.4rem;
  font-style:italic;
  color:#f5efe8;
  background:transparent;
  border:1px solid rgba(200,83,106,0.6);
  padding:18px 48px;
  cursor:pointer;
  letter-spacing:2px;
  transition:all 0.4s;
  position:relative;
  overflow:hidden;
}
.gift-btn::before {
  content:'';
  position:absolute;
  inset:0;
  background:rgba(200,83,106,0.08);
  transform:scaleX(0);
  transform-origin:left;
  transition:transform 0.4s ease;
}
.gift-btn:hover::before { transform:scaleX(1); }
.gift-btn:hover { border-color:rgba(200,83,106,1); letter-spacing:3px; }
.gift-btn.hidden { display:none; }

/* ENVELOPE */
.envelope-wrap {
  display:none;
  flex-direction:column;
  align-items:center;
  width:100%;
  max-width:600px;
}
.envelope-wrap.visible { display:flex; }

.envelope {
  width:100%;
  max-width:480px;
  position:relative;
  cursor:pointer;
}
.env-body {
  width:100%;
  height:260px;
  background:linear-gradient(145deg,#2a0e14,#1a080c);
  border:1px solid rgba(200,83,106,0.4);
  position:relative;
  overflow:hidden;
  transition:all 0.6s;
}
.env-body::after {
  content:'';
  position:absolute;
  bottom:0; left:0; right:0;
  height:50%;
  background:linear-gradient(to top, rgba(200,83,106,0.05), transparent);
}
.env-flap {
  width:100%;
  height:130px;
  background:linear-gradient(145deg,#3a1020,#220c12);
  border:1px solid rgba(200,83,106,0.4);
  border-bottom:none;
  clip-path: polygon(0 100%, 50% 0, 100% 100%);
  transform-origin:top;
  transition:transform 0.8s cubic-bezier(0.4,0,0.2,1);
  position:relative;
  z-index:2;
  margin-top:-1px;
}
.env-flap.open { transform:rotateX(180deg); }
.env-icon { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); font-size:2.5rem; }
.env-hint { font-family:'Cormorant Garamond',serif; font-style:italic; color:#c8819a; font-size:0.9rem; margin-top:12px; letter-spacing:2px; animation:pulse 2s ease-in-out infinite; }
@keyframes pulse { 0%,100%{opacity:0.5} 50%{opacity:1} }

/* CARTA */
.letter {
  display:none;
  flex-direction:column;
  align-items:center;
  width:100%;
  max-width:600px;
  margin-top:40px;
}
.letter.visible { display:flex; }

.letter-paper {
  background:rgba(255,255,255,0.03);
  border:1px solid rgba(200,83,106,0.2);
  padding:48px 40px;
  width:100%;
  text-align:center;
  position:relative;
}
.letter-paper::before {
  content:'';
  position:absolute;
  top:12px; left:12px; right:12px; bottom:12px;
  border:1px solid rgba(200,83,106,0.08);
  pointer-events:none;
}

.letter-line {
  font-family:'Cormorant Garamond',serif;
  font-size:1.2rem;
  font-style:italic;
  color:#c8a0aa;
  line-height:2;
  margin-bottom:20px;
  opacity:0;
  transform:translateY(16px);
  transition:opacity 0.9s ease, transform 0.9s ease;
}
.letter-line.show { opacity:1; transform:translateY(0); }
.letter-line.highlight {
  font-size:1.4rem;
  color:#e8a0b0;
}

.signature-block {
  margin-top:32px;
  opacity:0;
  transform:translateY(16px);
  transition:opacity 0.9s ease, transform 0.9s ease;
}
.signature-block.show { opacity:1; transform:translateY(0); }
.signature-divider { width:60px; height:1px; background:linear-gradient(to right,transparent,#c8536a,transparent); margin:0 auto 16px; }
.signature-name { font-family:'Cormorant Garamond',serif; font-size:1.6rem; color:#e8a0b0; font-style:italic; }
.signature-sub { font-family:'Cormorant Garamond',serif; font-size:0.95rem; color:#c8819a; font-style:italic; margin-top:6px; }

.footer { position:relative; z-index:1; text-align:center; padding:40px 20px; border-top:1px solid rgba(200,83,106,0.15); }
.footer p { font-family:'Cormorant Garamond',serif; font-size:1.4rem; color:#c8536a; font-style:italic; }

/* corações flutuantes */
.heart { position:fixed; pointer-events:none; z-index:0; font-size:1.2rem; opacity:0; animation:floatHeart linear forwards; }
@keyframes floatHeart { 0%{opacity:0;transform:translateY(0) scale(0.5)} 20%{opacity:0.8} 80%{opacity:0.4} 100%{opacity:0;transform:translateY(-80vh) scale(1.2)} }
</style>
</head>
<body>
<div class="petals" id="petals"></div>

<section class="hero">
  <div class="rose-decoration">🌹</div>
  <p class="subtitle-top">Feliz Dia das Mães</p>
  <h1 class="name">Carolina<br><span>Carvalho Cunha</span></h1>
  <div class="divider"></div>
  <p class="hero-text">Para a mulher que carrega o mundo com graça e que ensina, todos os dias, o que é amor verdadeiro.</p>
</section>

<section class="photos-section">
  <div class="photo-card">
    <div class="photo-frame">
      <div class="corner-dec tl"></div><div class="corner-dec tr"></div>
      <div class="corner-dec bl"></div><div class="corner-dec br"></div>
      <img src="data:image/jpeg;base64," alt="Carolina Carvalho Cunha" />
    </div>
    <div class="photo-caption"><p>Sua beleza vai além do que os olhos podem ver —<br>ela mora no sorriso de quem você cuida.</p></div>
  </div>
</section>

<section class="gift-section">
  <button class="gift-btn" id="giftBtn" onclick="openEnvelope()">Abrir presente 🎁</button>

  <div class="envelope-wrap" id="envelopeWrap">
    <div class="envelope" id="envelope" onclick="openLetter()">
      <div class="env-flap" id="envFlap"></div>
      <div class="env-body">
        <div class="env-icon">💌</div>
      </div>
    </div>
    <p class="env-hint" id="envHint">toque para abrir</p>
  </div>

  <div class="letter" id="letter">
    <div class="letter-paper">
      <p class="letter-line" id="l1">Mãe,</p>
      <p class="letter-line" id="l2">não existem palavras grandes o suficiente<br>para dizer o quanto você significa.</p>
      <p class="letter-line" id="l3">Você é o lar que carrego comigo onde quer que eu vá —<br>a voz que me acalma, os braços que me acolhem.</p>
      <p class="letter-line" id="l4">Obrigado por cada abraço,<br>por cada noite em claro,<br>por cada sorriso que você deu mesmo quando estava cansada.</p>
      <p class="letter-line highlight" id="l5">Você é a razão de tudo que há de bom em mim.</p>
      <p class="letter-line" id="l6">Hoje e sempre —<br>te amo mais do que consigo expressar. 💕</p>
      <div class="signature-block" id="sig">
        <div class="signature-divider"></div>
        <p class="signature-name">Pedro Carvalho</p>
        <p class="signature-sub">seu filho, com todo amor do mundo</p>
      </div>
    </div>
  </div>
</section>

<footer class="footer" id="footer" style="display:none">
  <p>Feliz Dia das Mães, Carolina ✨</p>
</footer>

<script>
const petalsContainer = document.getElementById('petals');
function createPetal() {
  const p = document.createElement('div');
  p.className = 'petal';
  p.style.left = Math.random()*100+'vw';
  p.style.animationDuration = (Math.random()*8+6)+'s';
  p.style.animationDelay = (Math.random()*10)+'s';
  p.style.width = (Math.random()*6+5)+'px';
  p.style.height = (Math.random()*8+8)+'px';
  petalsContainer.appendChild(p);
  setTimeout(()=>p.remove(), 18000);
}
for(let i=0;i<20;i++) setTimeout(createPetal, i*400);
setInterval(createPetal, 800);

function openEnvelope() {
  document.getElementById('giftBtn').classList.add('hidden');
  const wrap = document.getElementById('envelopeWrap');
  wrap.classList.add('visible');
  wrap.style.opacity = '0';
  wrap.style.transform = 'translateY(30px)';
  wrap.style.transition = 'opacity 0.8s ease, transform 0.8s ease';
  setTimeout(() => {
    wrap.style.opacity = '1';
    wrap.style.transform = 'translateY(0)';
  }, 50);
}

let envelopeOpened = false;
function openLetter() {
  if (envelopeOpened) return;
  envelopeOpened = true;
  document.getElementById('envFlap').classList.add('open');
  document.getElementById('envHint').style.opacity = '0';

  setTimeout(() => {
    document.getElementById('envelopeWrap').style.opacity = '0';
    document.getElementById('envelopeWrap').style.transform = 'translateY(-20px)';
    document.getElementById('envelopeWrap').style.transition = 'all 0.6s ease';
  }, 900);

  setTimeout(() => {
    document.getElementById('envelopeWrap').style.display = 'none';
    const letter = document.getElementById('letter');
    letter.classList.add('visible');
    letter.style.opacity = '0';
    letter.style.transition = 'opacity 0.8s ease';
    setTimeout(() => { letter.style.opacity = '1'; }, 50);
    revealLines();
  }, 1600);
}

function revealLines() {
  const lines = ['l1','l2','l3','l4','l5','l6','sig'];
  lines.forEach((id, i) => {
    setTimeout(() => {
      const el = document.getElementById(id);
      if (el) el.classList.add('show');
      if (i >= 2) spawnHearts();
    }, i * 900);
  });

  setTimeout(() => {
    document.getElementById('footer').style.display = 'block';
    document.getElementById('footer').style.opacity = '0';
    document.getElementById('footer').style.transition = 'opacity 1s ease';
    setTimeout(() => { document.getElementById('footer').style.opacity = '1'; }, 50);
  }, lines.length * 900 + 400);
}

function spawnHearts() {
  const emojis = ['💕','❤️','🌹','💗','💖'];
  for (let i = 0; i < 3; i++) {
    setTimeout(() => {
      const h = document.createElement('div');
      h.className = 'heart';
      h.textContent = emojis[Math.floor(Math.random()*emojis.length)];
      h.style.left = (Math.random()*80+10)+'vw';
      h.style.bottom = '10vh';
      h.style.animationDuration = (Math.random()*3+3)+'s';
      document.body.appendChild(h);
      setTimeout(() => h.remove(), 6000);
    }, i * 200);
  }
}
</script>
</body>
</html>
